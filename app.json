{
  "expo": {
    "name": "Pacto",
    "slug": "pacto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pacto",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pacto.app",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pacto uses your location to show local weather on your Home screen.",
        "NSMicrophoneUsageDescription": "Pacto uses the microphone to transcribe your AI assistant requests on this device.",
        "NSUserNotificationsUsageDescription": "Pacto sends reminders and notifies you when your partner adds something to your shared space."
      }
    },
    "android": {
      "package": "com.pacto.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#F5EEE3",
        "foregroundImage": "./assets/images/adaptive-icon-foreground.png",
        "backgroundImage": "./assets/images/adaptive-icon-background.png",
        "monochromeImage": "./assets/images/adaptive-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FAF8F2",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Pacto to show local weather on your Home screen."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Pacto needs camera access to scan an invite QR code."
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FAF8F2"
        }
      ],
      [
        "llama.rn",
        {
          "enableEntitlements": true,
          "entitlementsProfile": "production",
          "forceCxx20": true,
          "enableOpenCL": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
