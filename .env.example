EXPO_PUBLIC_INSTANT_APP_ID=
INSTANT_ADMIN_TOKEN=
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_URL_SCHEME=

# Production-readiness QA guardrails. Set only for a staging InstantDB clone.
COUPL_QA_ENV=
COUPL_QA_CONFIRM_APP_ID=
COUPL_QA_ALLOW_STAGING_WRITES=

# Optional Android Google auth preflight controls.
# Leave COUPL_QA_ANDROID_PLAY_STORE_AVD empty to accept any local Play Store AVD.
COUPL_QA_ANDROID_PLAY_STORE_AVD=
COUPL_QA_ANDROID_GOOGLE_AUTH_DEVICE=

# Android production release signing. Required for release builds.
COUPL_ANDROID_RELEASE_STORE_FILE=
COUPL_ANDROID_RELEASE_STORE_PASSWORD=
COUPL_ANDROID_RELEASE_KEY_ALIAS=
COUPL_ANDROID_RELEASE_KEY_PASSWORD=
